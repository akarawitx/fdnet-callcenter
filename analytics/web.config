<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!--
      บอก IIS ว่าไฟล์ใน folder analytics/ เปิดได้ปกติ
      tracker.php รับ POST จาก JS
      dashboard.php เปิดผ่าน browser ได้เลย
    -->

    <security>
      <requestFiltering>
        <!-- อนุญาต GET และ POST -->
        <verbs allowUnlisted="false">
          <add verb="GET"  allowed="true"/>
          <add verb="POST" allowed="true"/>
          <add verb="HEAD" allowed="true"/>
        </verbs>
      </requestFiltering>
    </security>

    <!-- ปิด directory browsing -->
    <directoryBrowse enabled="false"/>

    <!-- กัน browser cache สำหรับ tracker -->
    <staticContent>
      <clientCache cacheControlMode="DisableCache"/>
    </staticContent>

  </system.webServer>
</configuration>